###############################################################################
### Copy this file to .env and fill in real values                          ###
### DO NOT commit the .env file                                             ###
###############################################################################

# Ethereum private key for CRE CLI (hex with 0x prefix)
CRE_ETH_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Default CRE target (staging-settings or production-settings)
CRE_TARGET=staging-settings

# Secrets consumed by the DCA workflow (names match secrets.yaml mapping)
BACKEND_AUTH_TOKEN_ALL=changeme-local-dev-token
BACKEND_URL_ALL=http://localhost:3000
